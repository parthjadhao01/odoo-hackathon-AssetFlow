// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  DRAFT
  IN_PROGRESS
  CLOSED
}

enum AuditVerdict {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

// ---------------------------------------------------------------------------
// Org structure
// ---------------------------------------------------------------------------

model Department {
  id     String       @id @default(cuid())
  name   String       @unique
  status ActiveStatus @default(ACTIVE)

  parentDeptId String?
  parentDept   Department?  @relation("DepartmentHierarchy", fields: [parentDeptId], references: [id])
  childDepts   Department[] @relation("DepartmentHierarchy")

  headId String?   @unique
  head   Employee? @relation("DepartmentHead", fields: [headId], references: [id])

  employees   Employee[]   @relation("DepartmentEmployees")
  allocations Allocation[] @relation("AllocationDepartment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(EMPLOYEE)
  status       ActiveStatus @default(ACTIVE)

  departmentId String?
  department   Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])

  // Inverse side of Department.head (1—1)
  headOfDepartment Department? @relation("DepartmentHead")

  allocations               Allocation[]         @relation("AllocationEmployee")
  transfersRequestedFrom    Transfer[]           @relation("TransferFromEmployee")
  transfersRequestedTo      Transfer[]           @relation("TransferToEmployee")
  bookings                  Booking[]            @relation("BookingEmployee")
  maintenanceRequestsRaised MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  auditAssignments          AuditAssignment[]    @relation("AuditAssignmentAuditor")
  notifications             Notification[]       @relation("NotificationRecipient")
  activityLogs              ActivityLog[]        @relation("ActivityLogActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Assets
// ---------------------------------------------------------------------------

model AssetCategory {
  id          String @id @default(cuid())
  name        String @unique
  extraFields Json?

  assets Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id              String      @id @default(cuid())
  assetTag        String      @unique
  name            String
  status          AssetStatus @default(AVAILABLE)
  acquisitionCost Decimal?    @db.Decimal(12, 2)

  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id])

  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ---------------------------------------------------------------------------
// Allocation / Transfer
// ---------------------------------------------------------------------------

model Allocation {
  id     String           @id @default(cuid())
  status AllocationStatus @default(ACTIVE)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  // Holder is either an Employee or a Department (never both).
  employeeId String?
  employee   Employee? @relation("AllocationEmployee", fields: [employeeId], references: [id])

  departmentId String?
  department   Department? @relation("AllocationDepartment", fields: [departmentId], references: [id])

  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  returnedAt         DateTime?
  returnCondition    String?

  transfers Transfer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId, status])
  @@index([status, expectedReturnDate])
}

model Transfer {
  id     String         @id @default(cuid())
  status TransferStatus @default(REQUESTED)

  allocationId String
  allocation   Allocation @relation(fields: [allocationId], references: [id])

  fromEmployeeId String?
  fromEmployee   Employee? @relation("TransferFromEmployee", fields: [fromEmployeeId], references: [id])

  toEmployeeId String
  toEmployee   Employee @relation("TransferToEmployee", fields: [toEmployeeId], references: [id])

  requestedAt DateTime  @default(now())
  decidedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Booking
// ---------------------------------------------------------------------------

model Booking {
  id     String        @id @default(cuid())
  status BookingStatus @default(UPCOMING)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  bookedById String
  bookedBy   Employee @relation("BookingEmployee", fields: [bookedById], references: [id])

  startsAt DateTime
  endsAt   DateTime

  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId, startsAt, endsAt])
}

// ---------------------------------------------------------------------------
// Maintenance
// ---------------------------------------------------------------------------

model MaintenanceRequest {
  id     String            @id @default(cuid())
  status MaintenanceStatus @default(PENDING)

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  raisedById String
  raisedBy   Employee @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])

  description    String
  technicianName String?

  decidedAt  DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

model AuditCycle {
  id     String           @id @default(cuid())
  name   String
  status AuditCycleStatus @default(DRAFT)

  startedAt DateTime?
  closedAt  DateTime?

  assignments AuditAssignment[]
  items       AuditItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditAssignment {
  id String @id @default(cuid())

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  auditorId String
  auditor   Employee @relation("AuditAssignmentAuditor", fields: [auditorId], references: [id])

  createdAt DateTime @default(now())

  @@unique([auditCycleId, auditorId])
}

model AuditItem {
  id      String       @id @default(cuid())
  verdict AuditVerdict @default(PENDING)

  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  notes      String?
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([auditCycleId, assetId])
}

// ---------------------------------------------------------------------------
// Notifications / Activity Log
// ---------------------------------------------------------------------------

model Notification {
  id String @id @default(cuid())

  recipientId String
  recipient   Employee @relation("NotificationRecipient", fields: [recipientId], references: [id])

  type    String
  message String
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([recipientId, read])
}

model ActivityLog {
  id String @id @default(cuid())

  actorId String
  actor   Employee @relation("ActivityLogActor", fields: [actorId], references: [id])

  action     String
  targetId   String?
  targetType String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
}
